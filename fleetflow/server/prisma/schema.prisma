generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleType {
  TRUCK
  VAN
  BIKE
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  ON_DUTY
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(DISPATCHER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id              String           @id @default(uuid())
  name            String
  licensePlate    String           @unique
  maxCapacityKg   Float
  odometer        Float
  vehicleType     VehicleType
  acquisitionCost Float
  status          VehicleStatus    @default(AVAILABLE)
  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Driver {
  id                 String       @id @default(uuid())
  name               String
  licenseNumber      String       @unique
  licenseExpiryDate  DateTime
  licenseCategory    String
  safetyScore        Float        @default(100)
  status             DriverStatus @default(OFF_DUTY)
  trips              Trip[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model Trip {
  id               String     @id @default(uuid())
  vehicleId        String
  vehicle          Vehicle    @relation(fields: [vehicleId], references: [id])
  driverId         String
  driver           Driver     @relation(fields: [driverId], references: [id])
  cargoWeight      Float
  origin           String
  destination      String
  revenue          Float
  startOdometer    Float
  endOdometer      Float?
  status           TripStatus @default(DRAFT)
  dispatchedAt     DateTime?
  completedAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model MaintenanceLog {
  id          String   @id @default(uuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  serviceType String
  cost        Float
  date        DateTime
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FuelLog {
  id          String   @id @default(uuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  liters      Float
  cost        Float
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Expense {
  id          String   @id @default(uuid())
  description String
  amount      Float
  date        DateTime
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
