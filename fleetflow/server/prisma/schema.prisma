generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(DISPATCHER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id              String           @id @default(uuid())
  name            String
  licensePlate    String           @unique
  maxCapacityKg   Float
  odometer        Float
  vehicleType     VehicleType
  acquisitionCost Float
  status          VehicleStatus    @default(AVAILABLE)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  fuelLogs        FuelLog[]
  maintenanceLogs MaintenanceLog[]
  trips           Trip[]
}

model Driver {
  id                String           @id @default(uuid())
  name              String
  licenseNumber     String           @unique
  licenseExpiryDate DateTime
  licenseCategory   String
  safetyScore       Float            @default(100)
  status            DriverStatus     @default(OFF_DUTY)
  suspensionReason  String?
  complianceStatus  ComplianceStatus @default(COMPLIANT)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  trips             Trip[]
}

model Trip {
  id            String     @id @default(uuid())
  vehicleId     String
  driverId      String
  cargoWeight   Float
  origin        String
  destination   String
  revenue       Float
  startOdometer Float
  endOdometer   Float?
  status        TripStatus @default(DRAFT)
  dispatchedAt  DateTime?
  completedAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  driver        Driver     @relation(fields: [driverId], references: [id])
  vehicle       Vehicle    @relation(fields: [vehicleId], references: [id])
}

model MaintenanceLog {
  id          String   @id @default(uuid())
  vehicleId   String
  serviceType String
  cost        Float
  date        DateTime
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
}

model FuelLog {
  id        String   @id @default(uuid())
  vehicleId String
  liters    Float
  cost      Float
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
}

model Expense {
  id          String   @id @default(uuid())
  description String
  amount      Float
  date        DateTime
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Role {
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleType {
  TRUCK
  VAN
  BIKE
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  ON_DUTY
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum ComplianceStatus {
  COMPLIANT
  NON_COMPLIANT
  WARNING
}
